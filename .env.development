# OPC-HARNESS 开发环境配置
# 此文件用于本地开发，不会被提交到 Git

# ============================================
# AI Provider 配置
# ============================================

# AI Provider 类型（kimi/openai/anthropic/glm/minimax）
VITE_AI_PROVIDER=kimi

# AI API Key（请替换为你的实际 API Key）
VITE_AI_API_KEY=your-api-key-here

# AI 模型名称
VITE_AI_MODEL=kimi-k2.5

# ============================================
# 前端 Console Bridge 配置
# ============================================

# 开发模式默认启用 Console 桥接
VITE_ENABLE_CONSOLE_BRIDGE=true
