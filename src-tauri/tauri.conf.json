{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OPC-HARNESS",
  "version": "0.1.0",
  "identifier": "com.opc-harness.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OPC-HARNESS - AI 驱动的一人公司操作系统",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "default",
          "description": "Default capabilities",
          "local": true,
          "windows": ["main"],
          "permissions": [
            "core:default",
            "shell:allow-open",
            "dialog:allow-open",
            "dialog:allow-save",
            "core:app:allow-app-show",
            "core:window:allow-create",
            "core:window:allow-close",
            "core:window:allow-set-size",
            "core:window:allow-set-position",
            "fs:default",
            "fs:allow-read-text-file",
            "fs:allow-write-text-file",
            "fs:allow-read-dir",
            "fs:allow-copy-file",
            "fs:allow-create",
            "fs:allow-remove"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "AI驱动的一人公司操作系统",
    "longDescription": "OPC-HARNESS 为独立创造者整合产品构思、快速构建、增长运营三大模块，实现从想法到产品的全流程闭环。"
  }
}
