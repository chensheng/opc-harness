# OPC-HARNESS 环境变量配置示例
# 复制此文件为 .env.development 或 .env.production 并填写实际值

# ============================================
# Native Coding Agent 配置
# ============================================

# 是否启用 Native Coding Agent（默认 false，使用 CLI Agent）
# true: 使用纯 Rust 实现的 Native Agent（推荐）
# false: 使用基于 Kimi CLI 的传统 Agent（降级方案）
VITE_USE_NATIVE_AGENT=false

# AI Provider 类型
# 可选值: kimi, openai, anthropic, glm, minimax
VITE_AI_PROVIDER=kimi

# AI API Key（必需）
# 请从对应的 AI Provider 平台获取
VITE_AI_API_KEY=your-api-key-here

# AI 模型名称
# kimi: kimi-k2.5, kimi-plus
# openai: gpt-4, gpt-3.5-turbo
# anthropic: claude-3-opus, claude-3-sonnet
# glm: glm-4, glm-3.5-turbo
# minimax: abab6.5-chat, abab5.5-chat
VITE_AI_MODEL=kimi-k2.5

# ============================================
# 前端 Console Bridge 配置
# ============================================

# 是否启用前端 Console 桥接（开发模式默认启用）
# 启用后，前端的 console.log/error/warn 将转发到后端 Rust 日志系统
VITE_ENABLE_CONSOLE_BRIDGE=true

# ============================================
# Tauri 应用配置
# ============================================

# 应用端口（开发模式）
TAURI_DEV_PORT=1420

# WebSocket 端口
WEBSOCKET_PORT=8080

# ============================================
# 数据库配置
# ============================================

# SQLite 数据库路径
DATABASE_PATH=./data/opc-harness.db

# ============================================
# Git 配置
# ============================================

# Git 用户名（用于自动提交）
GIT_USER_NAME=OPC-HARNESS Bot

# Git 用户邮箱
GIT_USER_EMAIL=bot@opc-harness.local

# ============================================
# 日志配置
# ============================================

# Rust 日志级别
# 可选值: error, warn, info, debug, trace
RUST_LOG=info

# 是否启用详细日志（调试用）
# RUST_LOG=debug npm run tauri:dev

# ============================================
# 性能监控配置
# ============================================

# 是否启用性能监控
ENABLE_PERFORMANCE_MONITORING=true

# 性能数据上报间隔（秒）
PERFORMANCE_REPORT_INTERVAL=60

# ============================================
# 灰度发布配置
# ============================================

# Native Agent 灰度比例（0-100）
# 0: 完全禁用，100: 完全启用
NATIVE_AGENT_ROLLOUT_PERCENTAGE=0

# 白名单用户 ID（逗号分隔）
# 这些用户将始终使用 Native Agent
NATIVE_AGENT_WHITELIST_USERS=

# ============================================
# 其他配置
# ============================================

# 工作空间根目录（默认为项目根目录）
# WORKSPACE_ROOT=/path/to/workspace

# 最大并发 Agent 数量
MAX_CONCURRENT_AGENTS=5

# Agent 超时时间（秒）
AGENT_TIMEOUT_SECS=1800
